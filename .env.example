# Flask
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=change-me-in-development
DEBUG=True

# Database: works on Windows and Codespaces without extra services.
DATABASE_URL=sqlite:///instance/instagram_analytics.db
SQLALCHEMY_ECHO=False

# Instagram API placeholders
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id
INSTAGRAM_ACCESS_TOKEN=your_access_token
INSTAGRAM_API_VERSION=v18.0

# JWT
JWT_SECRET_KEY=change-me-too

# Optional Celery/Redis. Leave empty for synchronous local execution.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Server
HOST=0.0.0.0
PORT=3000
